// ==========================================
// PRISMA CLIENT & DATASOURCE
// ==========================================

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ==========================================
// ENUMS
// ==========================================

enum BookingStatus {
  PENDING_PERFORMER_APPROVAL // 1. Customer requested, waiting for performer
  REJECTED_BY_PERFORMER // 2a. Performer said no (Case Closed)
  PENDING_CUSTOMER_PAYMENT // 2b. Performer said yes, set price. Waiting for customer to pay
  CANCELLED_BY_CUSTOMER // 3a. Customer declined the price (Case Closed)
  CONFIRMED // 3b. Customer paid, funds in Escrow, calendar blocked
  FULFILLED // 4. Gig done, funds released to performer
  DISPUTED // 5. Customer raised an issue
}

enum NotificationType {
  SYSTEM
  NEW_MESSAGE
  ADMIN_ALERT
  NEW_BOOKING
  BOOKING_REQUEST
  BOOKING_UPDATE
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  MODERATION_UPDATE
  NEW_REQUEST
  PARTNER_REQUEST
  PARTNER_APPROVED
  PAYOUT_REQUEST
  SUPPORT_TICKET
  SUPPORT_UPDATE
}

enum EscrowStatus {
  NONE
  AWAITING_PAYMENT
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum SubscriptionTier {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  BLOCKED
}

enum WalletType {
  PAYMENT
  TOPUP
  REFUND
  PAYOUT
}

enum OrderStatus {
  INITIATED
  AWAITING_BANK_TRANSFER
  ACTIVE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  CANCELLED
  PAYMENT_PENDING
  EXPIRED
}

enum PaymentMethod {
  CARD
  INVOICE
}

enum TargetType {
  topic
  token
}

enum FCMStatus {
  SUCCESS
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum EventType {
  PUBLIC
  PRIVATE
}

enum PaymentType {
  FREE
  PAID
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketType {
  BUG_REPORT
  FEATURE_REQUEST
  BILLING
  TECHNICAL_SUPPORT
  GENERAL_INQUIRY
  OTHER
}

// ==========================================
// 1. BASE USER & AUTHENTICATION
// ==========================================

model User {
  id               String  @id @default(cuid())
  email            String  @unique
  password         String?
  name             String?
  phone            String?
  image            String?
  role             String  @default("customer")
  moderationStatus Status  @default(PENDING) @map("moderation_status")
  authProvider     String  @default("credentials") @map("auth_provider")

  // FCM and Onboarding
  fcmToken        String? @map("fcm_token")
  welcomePushSent Boolean @default(false) @map("welcome_push_sent")

  // NextAuth standard fields
  emailVerified      DateTime?           @map("email_verified")
  accounts           Account[]
  sessions           Session[]
  verificationTokens VerificationToken[]

  // Global Platform Features
  walletBalance      Float               @default(0) @map("wallet_balance")
  walletTransactions WalletTransaction[]
  chatsAsUser1       ChatSession[]       @relation("ChatUser1")
  chatsAsUser2       ChatSession[]       @relation("ChatUser2")
  messagesSent       ChatMessage[]
  notifications      Notification[]
  supportTickets     SupportTicket[]     @relation("RequesterSupport")
  payments           Payment[]
  orders             Order[]
  subscriptions      UserSubscription[]
  prompts            Prompt[]
  articleComments    ArticleComment[]
  articleLikes       ArticleLike[]
  usedPromoCodes     PromoCode[]         @relation("PromoCodeUsers")

  // Partner Referral Links
  referredById             String?         @map("referred_by_id")
  referredBy               PartnerProfile? @relation("ReferredUsers", fields: [referredById], references: [id], onDelete: SetNull)
  referralEventsAsReferred ReferralEvent[] @relation("ReferredUser")

  // 1-TO-1 DELEGATED PROFILES
  customerProfile  CustomerProfile?
  performerProfile PerformerProfile?
  partnerProfile   PartnerProfile?
  adminProfile     AdminProfile?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  feedPostLikes    FeedPostLike[]
  feedPostComments FeedPostComment[]

  // User explicitly holds the bookings they make
  bookingsMade   BookingRequest[] @relation("CustomerBookings")
  payoutRequests PayoutRequest[]

  @@index([email])
  @@index([role])
  @@index([authProvider])
  @@map("users")
}

// ==========================================
// 2. STRICTLY TYPED PROFILES
// ==========================================

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // 🚨 RESTRICTED: Do not delete profile directly if user exists
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  city              String?
  address           String?
  companyName       String? @map("company_name")
  inn               String?
  description       String? @db.Text
  accountType       String? @map("account_type")
  backgroundPicture String? @map("background_picture")
  preferences       Json?   @default("{}")
  moderationStatus  Status  @default(PENDING) @map("moderation_status")

  // 🚨 FIXED: Removed `bookingsRequests` from here, as they belong to `User`
  reviewsGiven Review[]      @relation("CustomerReviews")
  paidRequests PaidRequest[]
  favorites    Favorite[]    @relation("CustomerFavorites")

  @@map("customer_profiles")
}

