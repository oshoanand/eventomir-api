model PerformerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  companyName       String?  @map("company_name")
  inn               String?
  description       String?  @db.Text
  experience        String?
  priceRange        Int[]    @map("price_range")
  city              String?
  address           String?
  roles             String[]
  accountType       String?  @map("account_type")
  backgroundPicture String?  @map("background_picture")
  moderationStatus  Status   @default(PENDING) @map("moderation_status")

  reviewsReceived Review[]               @relation("PerformerReviews")
  galleryItems    GalleryItem[]
  certificates    Certificate[]
  audioTracks     AudioTrack[]
  eventsHosted    Event[]                @relation("HostedEvents")
  recommendations RecommendationLetter[]
  favoritedBy     Favorite[]             @relation("PerformerFavorites")

  socialLinks Json? @default("{}") @map("social_links")
  bankDetails Json? @default("[]") @map("bank_details")

  feedPosts FeedPost[]

  bookedDates      DateTime[]       @map("booked_dates")
  bookingsReceived BookingRequest[] @relation("PerformerBookings")

  // ✅ Arrays use native GIN
  @@index([roles], type: Gin)
  @@index([priceRange], type: Gin)
  // ✅ Strings MUST use the trigram operator class
  @@index([city(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([companyName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("performer_profiles")
}

model PartnerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  companyName      String? @map("company_name")
  inn              String?
  description      String? @db.Text
  city             String?
  address          String?
  accountType      String? @map("account_type")
  moderationStatus Status  @default(PENDING) @map("moderation_status")

  referralId           String  @unique @map("referral_id")
  balance              Float   @default(0)
  totalEarned          Float   @default(0) @map("total_earned")
  totalRegistrations   Int     @default(0) @map("total_registrations")
  totalPaidConversions Int     @default(0) @map("total_paid_conversions")
  clicks               Int     @default(0)
  minPayout            Float   @default(1500) @map("min_payout")
  paymentDetails       String? @map("payment_details") @db.Text

  referralEvents ReferralEvent[]
  payoutRequests PayoutRequest[]
  referredUsers  User[]          @relation("ReferredUsers")

  @@map("partner_profiles")
}

model AdminProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  accessLevel String @default("superadmin") @map("access_level")

  ticketsManaged SupportTicket[] @relation("ManagerSupport")

  @@map("admin_profiles")
}

model FeedPost {
  id        String   @id @default(cuid())
  text      String?  @db.Text
  imageUrls String[] @map("image_urls")
  videoUrl  String?  @map("video_url")
  isPublic  Boolean  @default(true) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)

  likes    FeedPostLike[]
  comments FeedPostComment[]

  @@index([performerId])
  @@index([createdAt])
  @@map("feed_posts")
}

model FeedPostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId])
  @@index([postId])
  @@map("feed_post_likes")
}

model FeedPostComment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  postId    String   @map("post_id")
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@map("feed_post_comments")
}

// ==========================================
// 3. NEXTAUTH MODELS
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  expires      DateTime
  sessionToken String   @unique @map("session_token")
  accessToken  String?  @unique @map("access_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         String    @id @default(cuid())
  identifier String?
  userId     String?   @map("user_id")
  token      String    @unique
  expires    DateTime?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, token])
  @@index([userId])
  @@map("verification_tokens")
}

// ==========================================
// 4. CORE PLATFORM MODELS
// ==========================================
model Review {
  id      String  @id @default(cuid())
  rating  Int
  comment String? @db.Text
  reply   String? @db.Text

  replyCreatedAt DateTime? @map("reply_created_at")
  replyUpdatedAt DateTime? @map("reply_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation("PerformerReviews", fields: [performerId], references: [id], onDelete: Cascade)

  customerId String          @map("customer_id")
  customer   CustomerProfile @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([performerId, customerId])
  @@index([performerId])
  @@index([customerId])
  @@map("reviews")
}

model PaidRequest {
  id                 String  @id @default(cuid())
  category           String
  serviceDescription String  @map("service_description") @db.Text
  city               String?
  budget             String?
  status             String  @default("PENDING_PAYMENT")
  views              Int     @default(0)
  responses          Int     @default(0)

  customerId String          @map("customer_id")
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  paymentId String?  @unique @map("payment_id")
  payment   Payment? @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([status])
  @@map("paid_requests")
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  customerId String          @map("customer_id")
  customer   CustomerProfile @relation("CustomerFavorites", fields: [customerId], references: [id], onDelete: Cascade)

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation("PerformerFavorites", fields: [performerId], references: [id], onDelete: Cascade)

  @@unique([customerId, performerId])
  @@index([customerId])
  @@index([performerId])
  @@map("favorites")
}

// ==========================================
// 5. MEDIA & CONTENT MODELS
// ==========================================

model GalleryItem {
  id               String   @id @default(cuid())
  title            String
  description      String?  @db.Text
  imageUrls        String[] @map("image_urls")
  moderationStatus String   @default("pending_approval") @map("moderation_status")
  metaTitle        String?  @map("meta_title")
  metaDescription  String?  @map("meta_description")
  keywords         String?
  imageAltText     String?  @map("image_alt_text")
  createdAt        DateTime @default(now()) @map("created_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)

  @@index([performerId])
  @@map("gallery_items")
}

model Certificate {
  id               String   @id @default(cuid())
  fileUrl          String   @map("file_url")
  description      String?  @db.Text
  moderationStatus String   @default("pending_approval") @map("moderation_status")
  createdAt        DateTime @default(now()) @map("created_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)

  @@index([performerId])
  @@map("certificates")
}

model RecommendationLetter {
  id               String   @id @default(cuid())
  fileUrl          String   @map("file_url")
  description      String?  @db.Text
  moderationStatus String   @default("pending_approval") @map("moderation_status")
  createdAt        DateTime @default(now()) @map("created_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)

  @@index([performerId])
  @@map("recommendation_letters")
}

model AudioTrack {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String   @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")

  performerId String           @map("performer_id")
  performer   PerformerProfile @relation(fields: [performerId], references: [id], onDelete: Cascade)

  @@index([performerId])
  @@map("audio_tracks")
}

// ==========================================
// 6. COMMUNICATION & SUPPORT MODELS
// ==========================================

model ChatSession {
  id        String   @id @default(cuid())
  status    String   @default("OPEN")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user1Id String @map("user1_id")
  user1   User   @relation("ChatUser1", fields: [user1Id], references: [id], onDelete: Cascade)

  user2Id String @map("user2_id")
  user2   User   @relation("ChatUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  messages      ChatMessage[]
  supportTicket SupportTicket?

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String    @id @default(cuid())
  text      String?   @db.Text
  imageUrl  String?   @map("image_url")
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  chatSessionId String      @map("chat_session_id")
  session       ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  replyToId String?       @map("reply_to_id")
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   ChatMessage[] @relation("MessageReplies")

  @@index([chatSessionId])
  @@index([senderId])
  @@map("chat_messages")
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber Int            @unique @default(autoincrement()) @map("ticket_number")
  subject      String
  description  String         @db.Text
  type         TicketType     @default(GENERAL_INQUIRY)
  priority     TicketPriority @default(NORMAL)
  status       TicketStatus   @default(OPEN)
  attachments  String[]

  requesterId   String? @map("requester_id")
  contactMobile String? @map("contact_mobile")
  contactEmail  String? @map("contact_email")

  assignedManagerId String? @map("assigned_manager_id")
  chatId            String? @unique @map("chat_id")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  closedAt        DateTime? @map("closed_at")

  requester       User?         @relation("RequesterSupport", fields: [requesterId], references: [id], onDelete: SetNull)
  assignedManager AdminProfile? @relation("ManagerSupport", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  chat            ChatSession?  @relation(fields: [chatId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([createdAt])
  @@index([requesterId])
  @@index([assignedManagerId])
  @@map("support_tickets")
}

model Notification {
  id        String           @id @default(cuid())
  title     String           @db.VarChar(255)
  message   String           @db.Text
  type      NotificationType
  data      Json?
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ==========================================
// 7. FINANCIAL & SUBSCRIPTION MODELS
// ==========================================

model Payment {
  id           String        @id @default(uuid())
  amount       Int
  currency     String        @default("RUB")
  status       PaymentStatus @default(PENDING)
  provider     String
  providerTxId String?       @map("provider_tx_id")
  metadata     Json?

  // --- ESCROW FIELDS ---
  platformFee     Float        @default(0)
  netAmount       Float        @default(0)
  escrowStatus    EscrowStatus @default(NONE)
  releaseEligible DateTime?
  payoutTxId      String?      @unique @map("payout_tx_id")
  // -----------------------------

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  bookingId String?         @map("booking_id")
  booking   BookingRequest? @relation(fields: [bookingId], references: [id])

  paidRequest PaidRequest?

  @@index([userId])
  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model SubscriptionPlan {
  id              String           @id @default(cuid())
  name            String
  description     String           @db.Text
  tier            SubscriptionTier @unique
  priceMonthly    Int              @default(0) @map("price_monthly")
  priceHalfYearly Int?             @default(0) @map("price_half_yearly")
  priceYearly     Int?             @default(0) @map("price_yearly")
  features        Json             @default("{}")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id             String             @id @default(cuid())
  startDate      DateTime           @default(now()) @map("start_date")
  endDate        DateTime?          @map("end_date")
  status         SubscriptionStatus @default(ACTIVE)
  pricePaid      Float?             @map("price_paid")
  discountAmount Float?             @map("discount_amount")
  autoRenew      Boolean            @default(false) @map("auto_renew")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String           @map("plan_id")
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  promoCodeId String?    @map("promo_code_id")
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@map("user_subscriptions")
}

model PromoCode {
  id                 String       @id @default(cuid())
  code               String       @unique
  type               DiscountType
  value              Float
  maxDiscountAmount  Float?       @map("max_discount_amount")
  minOrderAmount     Float?       @map("min_order_amount")
  isSingleUsePerUser Boolean      @default(false) @map("is_single_use_per_user")
  isActive           Boolean      @default(true) @map("is_active")
  currentUses        Int          @default(0) @map("current_uses")
  maxUses            Int?         @map("max_uses")
  validUntil         DateTime?    @map("valid_until")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  subscriptions UserSubscription[]
  usedByUsers   User[]             @relation("PromoCodeUsers")

  @@index([code])
  @@map("promo_codes")
}

model WalletTransaction {
  id          String     @id @default(cuid())
  amount      Float
  type        WalletType
  description String     @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("wallet_transactions")
}

// ==========================================
// 8. EVENTS & BLOG MODELS
// ==========================================

model Event {
  id               String      @id @default(cuid())
  title            String
  category         String
  type             EventType   @default(PRIVATE)
  paymentType      PaymentType @default(FREE) @map("payment_type")
  price            Float       @default(0)
  discountPrice    Float?      @default(0) @map("discount_price")
  date             DateTime
  time             String?
  city             String
  address          String?
  imageUrl         String      @map("image_url")
  description      String?     @db.Text
  totalTickets     Int         @default(0) @map("total_tickets")
  availableTickets Int         @default(0) @map("available_tickets")
  status           String      @default("active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  hostId String?           @map("host_id")
  host   PerformerProfile? @relation("HostedEvents", fields: [hostId], references: [id], onDelete: Cascade)

  orders      Order[]
  invitations Invitation[]

  @@index([hostId])
  @@index([date])
  @@index([city])
  @@map("events")
}

model Invitation {
  id          String     @id @default(cuid())
  guestName   String     @map("guest_name")
  guestEmail  String     @map("guest_email")
  guestPhone  String?    @map("guest_phone")
  status      RsvpStatus @default(PENDING)
  ticketToken String     @unique @default(uuid()) @map("ticket_token")
  isCheckedIn Boolean    @default(false) @map("is_checked_in")
  checkInTime DateTime?  @map("check_in_time")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, guestEmail])
  @@index([eventId])
  @@map("invitations")
}

model Order {
  id            String        @id @default(cuid())
  ticketCount   Int           @map("ticket_count")
  totalPrice    Float         @map("total_price")
  status        OrderStatus   @default(INITIATED)
  paymentId     String?       @map("payment_id")
  paymentMethod PaymentMethod @default(CARD) @map("payment_method")
  ticketCode    String        @unique @default(uuid()) @map("ticket_code")
  isUsed        Boolean       @default(false) @map("is_used")
  enteredAt     DateTime?     @map("entered_at")
  invoiceNumber String?       @unique @map("invoice_number")
  dueDate       DateTime?     @map("due_date")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("orders")
}

model Article {
  id              String   @id @default(cuid())
  title           String
  content         String   @db.Text
  slug            String   @unique
  mediaUrl        String?  @map("media_url")
  mediaType       String?  @map("media_type")
  metaTitle       String?  @map("meta_title")
  imageAltText    String?  @map("image_alt_text")
  metaDescription String?  @map("meta_description") @db.Text
  keywords        String?
  isActive        Boolean  @default(false) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  comments ArticleComment[]
  likes    ArticleLike[]

  @@index([slug])
  @@map("articles")
}

model ArticleComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  articleId String  @map("article_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?          @map("parent_id")
  parent   ArticleComment?  @relation("NestedComments", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ArticleComment[] @relation("NestedComments")

  @@index([articleId])
  @@index([userId])
  @@map("article_comments")
}

model ArticleLike {
  id String @id @default(cuid())

  articleId String  @map("article_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@index([articleId])
  @@map("article_likes")
}

// ==========================================
// 9. PARTNER MODELS
// ==========================================

model PartnershipRequest {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  city      String?
  website   String?
  status    Status   @default(PENDING)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("partnership_requests")
}

model ReferralEvent {
  id               String   @id @default(cuid())
  commissionAmount Float?   @map("commission_amount")
  eventType        String   @map("event_type")
  status           String?  @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")

  partnerId String         @map("partner_id")
  partner   PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  referredUserId String? @map("referred_user_id")
  referredUser   User?   @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([referredUserId])
  @@map("referral_events")
}

model PayoutRequest {
  id             String       @id @default(cuid())
  amount         Float
  status         PayoutStatus @default(PENDING)
  paymentDetails String?      @map("payment_details") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  partnerId String         @map("partner_id")
  partner   PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([status])
  @@map("payout_requests")
}

// ==========================================
// 10. SYSTEM SETTINGS & LOGS
// ==========================================

model SiteSettings {
  id              String   @id @default("general_settings")
  siteName        String   @default("Eventomir") @map("site_name")
  logoUrl         String?  @map("logo_url")
  logoAltText     String?  @map("logo_alt_text")
  faviconUrl      String?  @map("favicon_url")
  fontFamily      String   @default("Inter, sans-serif") @map("font_family")
  contacts        Json?    @default("{}")
  theme           Json?    @default("{\"backgroundColor\": \"#ffffff\", \"primaryColor\": \"#3b82f6\", \"accentColor\": \"#f59e0b\"}")
  siteCategories  Json     @default("[]") @map("site_categories")
  pageSpecificSEO Json     @default("[]") @map("page_specific_seo")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model PricingConfig {
  id         String   @id @default("pricing_config")
  configData Json?    @map("config_data")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("pricing_configs")
}

model Prompt {
  id        String   @id @default(cuid())
  prompt    String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("prompts")
}

model NotificationLog {
  id           String     @id @default(cuid())
  title        String
  body         String
  targetType   TargetType @map("target_type")
  target       String
  status       FCMStatus  @default(SUCCESS)
  messageId    String?    @map("message_id")
  sentAt       DateTime   @default(now()) @map("sent_at")
  errorDetails String?    @map("error_details")

  @@index([sentAt])
  @@map("notification_logs")
}

model SiteVisit {
  id        String   @id @default(cuid())
  ipAddress String   @map("ip_address")
  userAgent String?  @map("user_agent")
  path      String
  visitedAt DateTime @default(now()) @map("visited_at")
  visitDate DateTime @map("visit_date") @db.Date

  @@index([visitDate])
  @@index([ipAddress])
  @@map("site_visits")
}

model SecurityLog {
  id        String   @id @default(cuid())
  ipAddress String   @map("ip_address")
  eventType String   @map("event_type")
  path      String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ipAddress])
  @@index([eventType])
  @@map("security_logs")
}

// ==========================================
// 11. BOOKING REQUEST
// ==========================================

model BookingRequest {
  id          String           @id @default(uuid())
  performerId String
  performer   PerformerProfile @relation("PerformerBookings", fields: [performerId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User             @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  date    DateTime
  details String   @db.Text

  // --- NEW: Negotiation Fields ---
  agreedFee       Float?  @map("agreed_fee")
  rejectionReason String? @map("rejection_reason") @db.Text

  status BookingStatus @default(PENDING_PERFORMER_APPROVAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments  Payment[]
  auditLogs BookingAuditLog[] // Traceability

  @@index([customerId])
  @@index([performerId, date])
  @@index([status])
  @@map("booking_request")
}

model BookingAuditLog {
  id        String         @id @default(cuid())
  bookingId String         @map("booking_id")
  booking   BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  actorId  String @map("actor_id") // The User ID who performed the action (Customer, Performer, or System)
  action   String // e.g., "REQUEST_CREATED", "PRICE_PROPOSED", "PAYMENT_HELD"
  metadata Json? // Stores historical context (e.g., { "proposedFee": 50000 })

  createdAt DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([actorId])
  @@map("booking_audit_logs")
}
